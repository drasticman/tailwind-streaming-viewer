stream.andybader.com, stream.tailwindtech.xyz, tailwindtech.xyz {

	# Login page and assets must remain public.
	handle /login* {
		reverse_proxy 127.0.0.1:8081
	}

	handle /fulllogo.png {
		reverse_proxy 127.0.0.1:8081
	}

	# Everything below this point requires authentication.
	route {
		forward_auth 127.0.0.1:8081 {
			uri /auth/check
		}

		handle /stream-status* {
			reverse_proxy 127.0.0.1:8081
		}

		handle_path /webrtc/* {
			reverse_proxy 127.0.0.1:8889
		}

		handle_path /hls/* {
			reverse_proxy 127.0.0.1:8888
		}

		handle /A_Cam* {
			reverse_proxy 127.0.0.1:8889
		}

		handle /B_Cam* {
			reverse_proxy 127.0.0.1:8889
		}

		handle /C_Cam* {
			reverse_proxy 127.0.0.1:8889
		}

		handle /MultiAudio* {
			reverse_proxy 127.0.0.1:8888
		}

		# Viewer HTML, JavaScript, logos, and other static files.
		handle {
			root * C:\streaming\web
			file_server
		}
	}
}

files.tailwindtech.xyz {
	root * C:\Streaming\SharedFiles
	file_server browse
}